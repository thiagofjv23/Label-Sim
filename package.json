{
  "name": "chartwarsbrasil",
  "version": "0.0.1",
  "private": true,
  "description": "Simulacao de gestao de gravadora musical (Label-Sim). Motor de simulacao baseado em ticks.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate:charts": "tsx tools/generate-charts.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
